#!/bin/sh
# run-ada300-hetero.sh — generated by CMake (configure_file from cmake/run-ada300-hetero.sh.in)
# Do not edit directly; edit the .in template instead.
#
# Steps:
#   1. Create a fresh, zeroed shared memory file (rm+dd prevents stale ctrl data).
#   2. Start QEMU with the device firmware in the background.
#   3. Poll the UART log until the firmware reaches its "Polling" banner (max 15 s).
#   4. Run the host inference runner.
#   5. Print the device UART log.
#   6. Kill QEMU and propagate the host runner's exit code.
#
# CMake substitutions (@VAR@) are expanded at configure time.
# Shell ${VAR} syntax is left untouched.

set -e

SHM="@_SHM_PATH@"
QEMU_LOG="@_QEMU_LOG@"
UART_LOG="@_UART_LOG@"
QEMU="@ADA300_QEMU@"
DEV_ELF="@_DEV_ELF@"
RUNNER="@_RUNNER@"

# --- 1. Create a fresh, fully-zeroed shared memory file --------------------
echo "[run] Initialising shared memory at ${SHM}..."
rm -f "${SHM}"
dd if=/dev/zero of="${SHM}" bs=1M count=64 2>/dev/null

# --- 2. Start QEMU ---------------------------------------------------------
echo "[run] Starting QEMU (device firmware: ${DEV_ELF})..."
"${QEMU}" \
    -machine ada300s_evk -cpu ada300s \
    -nographic \
    -serial file:"${UART_LOG}" \
    -object memory-backend-file,id=shmem0,share=on,mem-path="${SHM}",size=64M \
    -kernel "${DEV_ELF}" \
    >"${QEMU_LOG}" 2>&1 &
QEMU_PID=$!

# --- 3. Wait for firmware "Polling" banner (up to 15 s) --------------------
echo "[run] Waiting for device firmware to reach polling loop (max 15 s)..."
i=0
while [ "${i}" -lt 15 ]; do
    if grep -q "Polling ivshmem" "${UART_LOG}" 2>/dev/null; then
        echo "[run] Firmware ready (${i} s)."
        break
    fi
    sleep 1
    i=$((i + 1))
done
if [ "${i}" -eq 15 ]; then
    echo "[run] WARNING: firmware polling banner not seen after 15 s; continuing anyway."
fi

# --- 4. Run host inference -------------------------------------------------
"${RUNNER}"
HOST_RC=$?

# --- 5. Device UART log ----------------------------------------------------
echo ""
echo "=== Device UART log ==="
cat "${UART_LOG}" 2>/dev/null || true

# --- 6. Cleanup ------------------------------------------------------------
kill "${QEMU_PID}" 2>/dev/null || true
wait "${QEMU_PID}" 2>/dev/null || true

if [ -s "${QEMU_LOG}" ]; then
    echo ""
    echo "=== QEMU messages ==="
    cat "${QEMU_LOG}"
fi

exit "${HOST_RC}"
